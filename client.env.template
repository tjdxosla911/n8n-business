# ============================================================
#  SNS 콘텐츠 자동화 - 고객 설정 파일
# ============================================================
#  사용법:
#  1. 이 파일을 복사해서 client.env 로 저장
#  2. 아래 값들을 고객 정보로 채움
#  3. Claude에게 이렇게 전달:
#     "C:\LAS_back\_handoff\requests\자동화비즈니스 폴더의
#      client.env 읽고, 01~07 가이드 순서대로 실행해줘"
# ============================================================

# ── 1. 고객 기본 정보 ─────────────────────────────────────────
# 고객사명 (서버 식별용, 영문소문자)
CLIENT_NAME=

# 도메인 (가비아 등에서 구매한 도메인)
# → n8n.도메인, chat.도메인, api.도메인, dash.도메인 자동 생성
DOMAIN=

# 관리자 이메일 (SSL 인증서 + Mattermost 관리자 계정)
ADMIN_EMAIL=

# ── 2. AWS 자격증명 ───────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-northeast-2
AWS_AZ=ap-northeast-2a

# ── 3. 서버 비밀번호 ─────────────────────────────────────────
# n8n 로그인
N8N_USER=admin
N8N_PASSWORD=

# n8n Basic Auth (Docker 접근 제어)
N8N_BASIC_AUTH_PASSWORD=

# PostgreSQL (n8n용)
DB_PASSWORD=

# ── 4. AI API ─────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── 5. Threads 연동 ──────────────────────────────────────────
# Meta 개발자 콘솔에서 Threads API 앱 등록 후 발급
THREADS_APP_ID=
THREADS_APP_SECRET=
THREADS_ACCESS_TOKEN=
# user_id는 토큰 발급 후 자동 조회 가능 (비워두면 설치 시 자동 조회)
THREADS_USER_ID=

# ── 6. SSH 키 ─────────────────────────────────────────────────
# Lightsail 기본 키 경로 (로컬 PC 기준)
SSH_KEY_PATH=

# ============================================================
#  아래는 설치 과정에서 자동 생성되는 값 (수동 입력 불필요)
# ============================================================
# SERVER_IP=                  ← 01단계에서 자동 할당
# N8N_URL=                    ← https://n8n.${DOMAIN}
# MATTERMOST_URL=             ← https://chat.${DOMAIN}
# BRIDGE_URL=                 ← https://api.${DOMAIN}
# DASHBOARD_URL=              ← https://dash.${DOMAIN}
# N8N_APPROVE_WEBHOOK=        ← https://n8n.${DOMAIN}/webhook/content-approve
# N8N_GENERATE_WEBHOOK=       ← https://n8n.${DOMAIN}/webhook/content-generate
# MATTERMOST_BOT_TOKEN=       ← 03단계에서 자동 생성
# MATTERMOST_CHANNEL_ID=      ← 03단계에서 자동 생성
